# =============================================================================
# wasac_analytics — environment config TEMPLATE
# Safe to commit — no real values here.
# Export the real values in ~/.bashrc on the server before running docker compose.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose — host settings
# -----------------------------------------------------------------------------
AIRFLOW_PROJ_DIR=.
_PIP_ADDITIONAL_REQUIREMENTS=

# -----------------------------------------------------------------------------
# PostgreSQL — Airflow metadata DB
# -----------------------------------------------------------------------------
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_PORT=55432

# -----------------------------------------------------------------------------
# PostgreSQL — Data Lake DB
# -----------------------------------------------------------------------------
POSTGRES_DATA_USER=${POSTGRES_DATA_USER}
POSTGRES_DATA_PWD=${POSTGRES_DATA_PWD}
POSTGRES_DATA_PORT=${POSTGRES_DATA_PORT}
POSTGRES_DATA_HOST=${POSTGRES_DATA_HOST}
POSTGRES_DATA_DB=${POSTGRES_DATA_DB}

# -----------------------------------------------------------------------------
# PgAdmin
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=${PGADMIN_DEFAULT_EMAIL}
PGADMIN_DEFAULT_PASSWORD=${PGADMIN_DEFAULT_PASSWORD}
PGADMIN_PORT=${PGADMIN_PORT}

# -----------------------------------------------------------------------------
# Airflow — core
# -----------------------------------------------------------------------------
AIRFLOW_UID=${AIRFLOW_UID}
AIRFLOW_GID=${AIRFLOW_GID}
DOCKER_AIRFLOW_HOME=${DOCKER_AIRFLOW_HOME}

AIRFLOW__CORE__FERNET_KEY=${AIRFLOW__CORE__FERNET_KEY}
AIRFLOW__CORE__DEFAULT_TIMEZONE=${AIRFLOW__CORE__DEFAULT_TIMEZONE}
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT=${AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT}
AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT=${AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT}
AIRFLOW__CORE__SQL_ALCHEMY_CONN=${AIRFLOW__CORE__SQL_ALCHEMY_CONN}
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=${AIRFLOW__CORE__SQL_ALCHEMY_CONN}
AIRFLOW__CELERY__RESULT_BACKEND=${AIRFLOW__CELERY__RESULT_BACKEND}
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0

AIRFLOW__WEBSERVER__SECRET_KEY=${AIRFLOW__WEBSERVER__SECRET_KEY}
AIRFLOW__WEBSERVER__WEB_SERVER_MASTER_TIMEOUT=${AIRFLOW__WEBSERVER__WEB_SERVER_MASTER_TIMEOUT}
AIRFLOW__WEBSERVER__WARN_DEPLOYMENT_EXPOSURE=False

AIRFLOW__SCHEDULER__PARSING_PROCESSES=${AIRFLOW__SCHEDULER__PARSING_PROCESSES}

AIRFLOW__LOGGING__LOG_CLEANUP=True
AIRFLOW_LOG_RETENTION_DAYS=10

SQLALCHEMY_SILENCE_UBER_WARNING=${SQLALCHEMY_SILENCE_UBER_WARNING}

# Airflow admin UI account
_AIRFLOW_WWW_USER_USERNAME=${_AIRFLOW_WWW_USER_USERNAME}
_AIRFLOW_WWW_USER_PASSWORD=${_AIRFLOW_WWW_USER_PASSWORD}

AIRFLOW_CONN_AIRFLOW=${AIRFLOW_CONN_AIRFLOW}

# OpenMetadata
OPENMENTA_USER=${OPENMENTA_USER}
OPENMENTA_PASSWORD=${OPENMENTA_PASSWORD}

# -----------------------------------------------------------------------------
# Airflow Variables — ETL paths & runtime
# -----------------------------------------------------------------------------
AIRFLOW_VAR_environment=${AIRFLOW_VAR_ENVIRONMENT}
AIRFLOW_VAR_modules_path=${AIRFLOW_VAR_MODULES_PATH}
AIRFLOW_VAR_config_path=${AIRFLOW_VAR_CONFIG_PATH}
AIRFLOW_VAR_sql_path=${AIRFLOW_VAR_SQL_PATH}
AIRFLOW_VAR_etl_path=${AIRFLOW_VAR_ETL_PATH}
AIRFLOW_VAR_template_path=${AIRFLOW_VAR_TEMPLATE_PATH}
AIRFLOW_VAR_data_dump=${AIRFLOW_VAR_DATA_DUMP}
AIRFLOW_VAR_logs_path=${AIRFLOW_VAR_LOGS_PATH}
AIRFLOW_VAR_dag_home=${AIRFLOW_VAR_DAG_HOME}
AIRFLOW_VAR_slack_token=${AIRFLOW_VAR_SLACK_TOKEN}

# Airflow Variables — Data Warehouse
AIRFLOW_VAR_dw_config_path=${AIRFLOW_VAR_DW_CONFIG_PATH}
AIRFLOW_VAR_dw_template_path=${AIRFLOW_VAR_DW_TEMPLATE_PATH}
AIRFLOW_VAR_dw_etl_path=${AIRFLOW_VAR_DW_ETL_PATH}
AIRFLOW_VAR_dw_sql_path=${AIRFLOW_VAR_DW_SQL_PATH}
AIRFLOW_VAR_dw_default_schema=${AIRFLOW_VAR_DW_DEFAULT_SCHEMA}
AIRFLOW_VAR_dw_log_retention_days=${AIRFLOW_VAR_DW_LOG_RETENTION_DAYS}

# -----------------------------------------------------------------------------
# Web UI (Flask — port 5001)
# -----------------------------------------------------------------------------
WEBUI_SECRET_KEY=${WEBUI_SECRET_KEY}
WEBUI_ADMIN_USER=${WEBUI_ADMIN_USER}
WEBUI_ADMIN_PASS=${WEBUI_ADMIN_PASS}

