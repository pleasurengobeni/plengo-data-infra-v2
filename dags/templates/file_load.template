# File cleaning helpers
# ─────────────────────────────────────────────────────────────────────────────

def _find_file(watch_path: str, file_name: str):  # -> Optional[str]
    """Return the full path if file_name exists in watch_path, otherwise None."""
    if not os.path.isdir(watch_path):
        return None
    fpath = os.path.join(watch_path, file_name)
    return fpath if os.path.isfile(fpath) else None


def _compute_md5(file_path: str) -> str:
    """Return MD5 hex digest of the file at file_path."""
    h = hashlib.md5()
    with open(file_path, "rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def _clean_col(name: str) -> str:
    """Normalise a column name: strip accents, lower, replace non-alphanum with _."""
    # NFD decompose → strip combining marks (accents etc.)
    name = unicodedata.normalize("NFD", str(name))
    name = "".join(c for c in name if unicodedata.category(c) != "Mn")
    # lower + replace anything that isn't a-z 0-9 with _
    name = re.sub(r"[^a-z0-9]+", "_", name.lower()).strip("_")
    # protect SQL reserved words
    reserved = {"from", "select", "where", "group", "order", "having",
                "user", "table", "index", "start", "end", "begin", "if"}
    if name in reserved:
        name = name + "_"
    return name or "col"


def _detect_encoding(path: str) -> str:
    """Read a sample of the file and detect its character encoding."""
    try:
        import chardet
        with open(path, "rb") as fh:
            sample = fh.read(65536)
        result = chardet.detect(sample)
        enc = result.get("encoding") or "utf-8"
        # Normalise common aliases
        enc = enc.upper().replace("-", "")
        aliases = {"ASCII": "utf-8", "UTF8": "utf-8", "UTF8BOM": "utf-8-sig",
                   "UTF16": "utf-16", "LATIN1": "latin-1", "ISO88591": "latin-1"}
        return aliases.get(enc, result.get("encoding", "utf-8"))
    except Exception:
        return "utf-8"


def _read_file(cfg: dict, file_path: str) -> "pd.DataFrame":
    """Read CSV or Parquet into a clean DataFrame with robust handling."""
    import numpy as np
    import pandas as pd

    file_format = cfg["file_format"].lower()
    null_vals   = cfg["null_values"]

    if not os.path.exists(file_path):
        raise FileNotFoundError(f"Source file not found: {file_path}")

    # ── Parquet (no encoding / ASCII issues) ──────────────────────────────
    if file_format == "parquet":
        df = pd.read_parquet(file_path)
        df.columns = [_clean_col(c) for c in df.columns]
        return df

    # ── CSV ───────────────────────────────────────────────────────────────
    encoding_cfg = cfg.get("encoding", "auto")
    encoding = _detect_encoding(file_path) if encoding_cfg == "auto" else encoding_cfg

    delimiter = cfg.get("delimiter", ",")
    has_header = cfg.get("has_header", True)
    skip_rows  = cfg.get("skip_rows", 0)

    logging.info(f"[file_load] Reading CSV: {file_path} | enc={encoding} | sep={repr(delimiter)}")

    read_kwargs = dict(
        filepath_or_buffer=file_path,
        sep=delimiter,
        header=0 if has_header else None,
        skiprows=skip_rows if skip_rows else None,
        encoding=encoding,
        encoding_errors="replace",
        na_values=null_vals,
        keep_default_na=True,
        low_memory=False,
        dtype=str,
    )

    try:
        df = pd.read_csv(**read_kwargs)
    except UnicodeDecodeError:
        logging.warning("[file_load] Encoding fallback to latin-1")
        read_kwargs["encoding"] = "latin-1"
        df = pd.read_csv(**read_kwargs)

    # ── Clean column names ────────────────────────────────────────────────
    df.columns = [_clean_col(c) for c in df.columns]

    # ── Strip whitespace from all string cells ────────────────────────────
    str_cols = df.select_dtypes(include="object").columns
    df[str_cols] = df[str_cols].apply(lambda s: s.str.strip())

    # ── Re-apply null sentinel values after strip ─────────────────────────
    null_set = {str(v).strip().lower() for v in null_vals}
    for col in str_cols:
        df[col] = df[col].where(~df[col].str.lower().isin(null_set), other=np.nan)

    # ── Remove non-printable / non-ASCII control characters ──────────────
    ctrl_re = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")
    for col in str_cols:
        df[col] = df[col].apply(
            lambda x: ctrl_re.sub("", x) if isinstance(x, str) else x
        )

    return df


def _cast_types(df: "pd.DataFrame", cfg: dict) -> "pd.DataFrame":
    """Apply dtype_overrides and infer numeric/date types safely."""
    import numpy as np
    import pandas as pd

    date_cols     = cfg.get("date_columns", [])
    dtype_overrides = cfg.get("dtype_overrides", {})

    # ── Apply explicit overrides first ────────────────────────────────────
    for raw_col, dtype in dtype_overrides.items():
        col = _clean_col(raw_col)
        if col not in df.columns:
            continue
        try:
            if dtype in ("int", "int64", "integer", "bigint"):
                df[col] = pd.to_numeric(df[col], errors="coerce").astype("Int64")
            elif dtype in ("float", "float64", "numeric", "decimal"):
                df[col] = pd.to_numeric(df[col], errors="coerce")
            elif dtype in ("bool", "boolean"):
                df[col] = df[col].map(
                    {"true": True, "false": False, "1": True, "0": False,
                     "yes": True, "no": False, "y": True, "n": False}
                )
            elif dtype in ("date", "timestamp", "datetime"):
                df[col] = pd.to_datetime(df[col], errors="coerce", infer_datetime_format=True)
            else:
                df[col] = df[col].astype(str)
        except Exception as exc:
            logging.warning(f"[file_load] dtype override failed for '{col}' → {dtype}: {exc}")

    # ── Explicit date columns ─────────────────────────────────────────────
    for raw_col in date_cols:
        col = _clean_col(raw_col)
        if col in df.columns and col not in dtype_overrides:
            df[col] = pd.to_datetime(df[col], errors="coerce", infer_datetime_format=True)

    # ── Auto-infer numerics for remaining object columns ──────────────────
    already_typed = set(_clean_col(c) for c in dtype_overrides) | set(_clean_col(c) for c in date_cols)
    for col in df.select_dtypes(include="object").columns:
        if col in already_typed:
            continue
        numeric = pd.to_numeric(df[col], errors="coerce")
        # Only promote if ≥ 80 % of non-null values parsed successfully
        non_null = df[col].notna().sum()
        parsed   = numeric.notna().sum()
        if non_null > 0 and parsed / non_null >= 0.8:
            df[col] = numeric

    return df


def _apply_transformations(df: "pd.DataFrame", cfg: dict) -> "pd.DataFrame":
    """Rename columns and apply value replace_values from config."""
    rename_map = {}
    for entry in cfg.get("rename_columns", []):
        for old, new in entry.items():
            rename_map[_clean_col(old)] = _clean_col(new)
    if rename_map:
        df = df.rename(columns=rename_map)

    # transformations list: [{col: new_type}, ...]  — already handled in _cast_types
    return df


