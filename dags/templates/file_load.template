def _get_target_engine():
    from airflow.hooks.base import BaseHook
    from sqlalchemy import create_engine

    conn_id  = CONFIG["target"]["target_db_conn_id"]
    conn     = BaseHook.get_connection(conn_id)
    db_type  = CONFIG["target"].get("db_type", "postgresql")

    port = conn.port or 5432
    if db_type == "mysql":
        url = f"mysql+pymysql://{conn.login}:{conn.password}@{conn.host}:{port}/{conn.schema}"
    elif db_type in ("mssql", "sqlserver"):
        url = f"mssql+pyodbc://{conn.login}:{conn.password}@{conn.host}:{port}/{conn.schema}?driver=ODBC+Driver+17+for+SQL+Server"
    else:
        url = f"postgresql+psycopg2://{conn.login}:{conn.password}@{conn.host}:{port}/{conn.schema}"

    return create_engine(url, pool_pre_ping=True)


def _checksum_already_registered(schema: str, table: str, checksum: str) -> bool:
    """Return True if this MD5 checksum is already in pipeline.file_load_registry for this target."""
    from sqlalchemy import text
    engine = _get_target_engine()
    try:
        with engine.connect() as conn:
            r = conn.execute(
                text("""
                    SELECT 1 FROM pipeline.file_load_registry
                    WHERE target_schema = :s AND target_table = :t AND file_checksum = :c
                    LIMIT 1
                """),
                {"s": schema, "t": table, "c": checksum},
            )
            return r.fetchone() is not None
    except Exception:
        return False


def _ensure_registry_table(conn):
    """Create pipeline.file_load_registry if it doesn't exist."""
    from sqlalchemy import text
    conn.execute(text("CREATE SCHEMA IF NOT EXISTS pipeline"))
    conn.execute(text("""
        CREATE TABLE IF NOT EXISTS pipeline.file_load_registry (
            id              SERIAL PRIMARY KEY,
            dag_id          TEXT,
            target_schema   TEXT,
            target_table    TEXT,
            file_name       TEXT,
            file_path       TEXT,
            file_checksum   TEXT,
            file_size_bytes BIGINT,
            rows_loaded     BIGINT,
            run_id          TEXT,
            loaded_at       TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
            archived_to     TEXT,
            archived_at     TIMESTAMP WITH TIME ZONE
        )
    """))
    conn.execute(text("""
        CREATE UNIQUE INDEX IF NOT EXISTS ux_file_registry_checksum
            ON pipeline.file_load_registry (target_schema, target_table, file_checksum)
    """))


