def load_config(dag_name):
    config_path = Variable.get(
        "config_path", default_var=os.path.join(os.getcwd(), "dags", "config")
    )
    pattern = os.path.join(config_path, "**", f"*{dag_name.lower()}*.json")
    matches = glob.glob(pattern, recursive=True)
    if not matches:
        raise FileNotFoundError(
            f"Config file for '{dag_name}' not found under '{config_path}'"
        )
    config = read_json_file(matches[0])
    env = Variable.get("environment", "dev")

    if "source" in config and env in config.get("source", {}):
        source_cfg = config["source"][env]
        target_cfg = config["target"][env]
    else:
        source_cfg = config["source"]
        target_cfg = config["target"]

    watch_path   = source_cfg.get("watch_path", "")
    archive_path = source_cfg.get("archive_path") or os.path.join(watch_path, "archive")

    return {
        "dag_id":            config.get("dag_id", f"FILE_{dag_name}"),
        "schedule_interval": config.get("schedule_interval"),
        "start_date":        config.get("start_date", "2023-01-01"),
        "source": {
            # Stable shared drop folder — never changes
            "watch_path":              watch_path,
            # Exact filename to match in the drop folder
            "file_name":               source_cfg.get("file_name") or source_cfg.get("file_pattern", ""),
            # csv | parquet
            "file_format":             source_cfg.get("file_format", "csv"),
            # CSV-specific
            "delimiter":               source_cfg.get("delimiter", ","),
            "encoding":                source_cfg.get("encoding", "auto"),
            "has_header":              source_cfg.get("has_header", True),
            "null_values":             source_cfg.get("null_values", ["", "NULL", "null", "None", "NA", "N/A", "n/a", "#N/A"]),
            "date_columns":            source_cfg.get("date_columns", []),
            "dtype_overrides":         source_cfg.get("dtype_overrides", {}),
            "skip_rows":               source_cfg.get("skip_rows", 0),
            # Archive config
            "archive_path":            archive_path,
            "archive_retention_days":  int(source_cfg.get("archive_retention_days", 30)),
        },
        "target": {
            "target_db_conn_id": target_cfg.get("target_db_conn_id"),
            "db_type":           target_cfg.get("db_type", "postgresql"),
            "target_schema":     target_cfg.get("target_schema") or target_cfg.get("target_table_schema"),
            "target_table":      target_cfg.get("target_table")  or target_cfg.get("target_table_name"),
        },
        "transformations":   config.get("transformations", []),
        "rename_columns":    config.get("rename_columns", []),
        "tags":              config.get("tags", ["ETL", "FILE", "file-etl"]),
        "source_type":       "file",
    }


