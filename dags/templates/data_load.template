def _resolve_sql_path(sql_base, dag_name, sql_file=None):
    import glob
    # 1. Genuine absolute path — use as-is
    if sql_file and os.path.isabs(sql_file):
        return sql_file
    # 2. Relative path (e.g. conn_id/file.sql) — always join with sql_base
    if sql_file:
        return os.path.join(sql_base, sql_file)
    # 3. No sql_file in config — glob search for any matching file across subdirs
    matches = glob.glob(os.path.join(sql_base, "**", f"*{dag_name.lower()}*.sql"), recursive=True)
    if matches:
        return matches[0]
    # 4. Last resort fallback
    return os.path.join(sql_base, f"{dag_name.lower()}.sql")

SQL_PATH = _resolve_sql_path(SQL_BASE, dag_name, CONFIG.get("sql_file"))


def ensure_schema_exists(schema_name):
    hook = get_hook(CONFIG["target"]["target_db_conn_id"])
    engine = create_engine(hook.get_uri())
    with engine.begin() as conn:
        conn.execute(text(f"CREATE SCHEMA IF NOT EXISTS {schema_name}"))


def _ensure_pipeline_metadata_columns(schema: str, table: str):
    """ALTER TABLE to add pipeline metadata columns if they don't exist yet.
    Safe to call every run — IF NOT EXISTS is idempotent."""
    hook   = get_hook(CONFIG["target"]["target_db_conn_id"])
    engine = create_engine(hook.get_uri())
    cols = [
        ("_pipeline_inserted_at", "TIMESTAMP"),
        ("_pipeline_run_id",      "TEXT"),
        ("_source_system",        "TEXT"),
        ("_loaded_at",            "TIMESTAMP"),
        ("_row_checksum",         "TEXT"),
    ]
    with engine.begin() as conn:
        for col_name, col_type in cols:
            conn.execute(text(
                f"ALTER TABLE {schema}.{table} "
                f"ADD COLUMN IF NOT EXISTS {col_name} {col_type}"
            ))


def pandas_dtype_to_sql(dtype):
    if pd.api.types.is_integer_dtype(dtype):
        return BigInteger()
    if pd.api.types.is_float_dtype(dtype):
        return Float()
    if pd.api.types.is_bool_dtype(dtype):
        return Boolean()
    if pd.api.types.is_datetime64_any_dtype(dtype):
        return DateTime()
    # dtype.kind == 'M' covers all datetime64 variants; numpy date scalars have kind == 'O'
    # Use hasattr guard for numpy dtypes that expose .type
    if hasattr(dtype, 'type') and issubclass(dtype.type, __import__('datetime').date):
        return Date()
    return Text()


def build_sqlalchemy_dtypes(df):
    return {col: pandas_dtype_to_sql(dtype) for col, dtype in df.dtypes.items()}


def _hwm_expressions(incremental_column, incremental_column_datatype, last_loaded):
    """
    Return (order_expr, where_clause) for the given incremental column.
    order_expr  : SQL expression to cast the column to a comparable type
    where_clause: SQL predicate filtering rows strictly AFTER last_loaded,
                  or None when last_loaded is None (full-load / first-run).
    """
    datatype = (incremental_column_datatype or "").lower()
    is_numeric = datatype in ("int", "bigint")
    if is_numeric:
        order_expr   = f"CAST({incremental_column} AS BIGINT)"
        where_clause = f"{order_expr} > {int(last_loaded)}" if last_loaded is not None else None
    else:
        order_expr   = f"CAST({incremental_column} AS TIMESTAMP)"
        where_clause = f"{order_expr} > '{last_loaded}'" if last_loaded is not None else None
    return order_expr, where_clause


def build_batch_temp_sql(base_sql, incremental_column, last_loaded, batch_size, incremental_column_datatype):
    """
    Returns the SQL to populate _etl_batch_tmp.

    last_loaded=None means either full_load=True or first incremental run —
    in both cases load all source rows (no WHERE filter), ordered by HWM if
    incremental_column is set so subsequent runs can pick up from the right place.
    """
    if not incremental_column:
        # No incremental column configured — always a straight full load
        return base_sql

    order_expr, _ = _hwm_expressions(incremental_column, incremental_column_datatype, None)

    if last_loaded is None:
        # First run or full_load=True: no HWM filter, load everything ordered
        if batch_size and batch_size > 0:
            sql = (
                f"SELECT * FROM ({base_sql}) _src "
                f"ORDER BY {order_expr} "
                f"LIMIT {batch_size}"
            )
        else:
            sql = (
                f"SELECT * FROM ({base_sql}) _src "
                f"ORDER BY {order_expr}"
            )
    else:
        _, where_clause = _hwm_expressions(incremental_column, incremental_column_datatype, last_loaded)
        if batch_size and batch_size > 0:
            sql = (
                f"SELECT * FROM ({base_sql}) _src "
                f"WHERE {where_clause} "
                f"ORDER BY {order_expr} "
                f"LIMIT {batch_size}"
            )
        else:
            sql = (
                f"SELECT * FROM ({base_sql}) _src "
                f"WHERE {where_clause} "
                f"ORDER BY {order_expr}"
            )

    logging.info("Batch temp SQL: %s", sql)
    return sql


def build_final_select_sql(incremental_column, incremental_column_datatype):
    """
    Returns the SQL to read the final boundary-inclusive result from the temp
    table _etl_batch_tmp.

    Why boundary-inclusive:
      The batch LIMIT may have cut off mid-tie (multiple rows share the exact
      same HWM value as the last row in the batch).  We rejoin the source for
      only those tied rows using the MAX already stored in the temp table —
      one cheap indexed lookup, not a second full scan of base_sql.

    Final ORDER BY ensures Pandas/the loader always sees rows in ascending
    HWM order, which is required for get_last_loaded_value() to advance
    the watermark correctly on subsequent runs.
    """
    if not incremental_column:
        return "SELECT * FROM _etl_batch_tmp"

    order_expr, _ = _hwm_expressions(incremental_column, incremental_column_datatype, None)

    sql = (
        f"SELECT * FROM _etl_batch_tmp "
        f"ORDER BY {order_expr}"
    )
    logging.info("Final select SQL: %s", sql)
    return sql


def get_last_loaded_value():
    """
    Returns the current HWM (high-water mark) from the target table, or None
    if this is a full load run.

    Rules (driven entirely by config, never defaulting silently):
      - full_load=True   : always return None — caller skips HWM filter
      - incremental_column not set : return None — no filter possible
      - target empty / missing     : return None — first incremental run,
                                     caller will load everything from source
                                     (no silent 1900 default — that is a full
                                     load disguised as incremental)
    """
    if CONFIG["source"].get("full_load", False):
        logging.info("get_last_loaded_value: full_load=True — skipping HWM query.")
        return None

    incremental_column = CONFIG["source"]["incremental_column"]
    if not incremental_column:
        return None

    target_hook = get_hook(CONFIG["target"]["target_db_conn_id"])
    schema = CONFIG["target"]["target_table_schema"]
    table  = CONFIG["target"]["target_table_name"]
    query  = f"SELECT MAX({incremental_column}) AS max_val FROM {schema}.{table}"
    try:
        result = target_hook.get_first(query)
        value  = result[0] if result else None
        if value is None:
            # Table exists but is empty — first incremental run, no HWM yet.
            # Return None so build_batch_temp_sql loads all source rows.
            logging.info(
                "get_last_loaded_value: %s.%s is empty — first incremental load.",
                schema, table,
            )
        return value
    except Exception as e:
        # Table does not exist yet (create_target just ran).
        logging.warning(
            "get_last_loaded_value: could not read HWM from %s.%s (%s) — first load.",
            schema, table, e,
        )
        return None


