def clean_string(input_string):
    return re.sub(r"[^a-zA-Z0-9\-_.]", "_", input_string)


def load_config(dag_name):
    import glob
    config_path = Variable.get(
        "config_path", default_var=os.path.join(os.getcwd(), "dags", "config")
    )
    # Search recursively: supports both legacy flat layout and new <conn_id>/<conn_id>_<dag>.json layout
    pattern = os.path.join(config_path, "**", f"*{dag_name.lower()}*.json")
    matches = glob.glob(pattern, recursive=True)
    if not matches:
        raise FileNotFoundError(
            f"Config file for '{dag_name}' not found under '{config_path}'"
        )
    config = read_json_file(matches[0])
    env = Variable.get("environment", "dev")
    if "source" in config and env in config.get("source", {}):
        source_cfg = config["source"][env]
        target_cfg = config["target"][env]
    else:
        source_cfg = config["source"]
        target_cfg = config["target"]

    source_schema = source_cfg.get("source_table_schema") or source_cfg.get("source_schema")
    source_table = source_cfg.get("source_table_name") or source_cfg.get("source_table")

    target_db = target_cfg.get("target_db") or target_cfg.get("target_schema")
    target_schema = target_cfg.get("target_table_schema") or target_cfg.get("target_schema")
    target_table = target_cfg.get("target_table_name") or target_cfg.get("target_table")

    return {
        "dag_id": config.get("dag_id", f"ETL_{dag_name}"),
        "schedule_interval": config.get("schedule_interval"),
        "start_date": config.get("start_date", "2023-01-01"),
        "source": {
            "source_db_conn_id": source_cfg.get("source_db_conn_id"),
            "db_type": source_cfg.get("db_type"),
            "source_table_schema": source_schema,
            "source_table_name": source_table,
            "incremental_column": source_cfg.get("incremental_column"),
            "incremental_column_datatype": source_cfg.get("incremental_column_datatype"),
            "limit": source_cfg.get("limit"),
            "full_load": source_cfg.get("full_load", False),
            "batch_size": source_cfg.get("batch_size") if source_cfg.get("batch_size") is not None else config.get("batch_size", 0),
        },
        "target": {
            "target_db_conn_id": target_cfg.get("target_db_conn_id"),
            "target_db": target_db,
            "target_table_schema": target_schema,
            "target_table_name": target_table,
            "incremental_column": target_cfg.get("incremental_column"),
            "db_type": target_cfg.get("db_type", "postgresql"),
        },
        "read_chunk_size": config.get("read_chunk_size", 50000),
        "transformations": config.get("transformations", []),
        "rename_columns": config.get("rename_columns", []),
        "replace_values": config.get("replace_values", []),
        "target_ddl": config.get("target_ddl"),
        # sql_file comes from the active env's source block so dev/prod get different queries
        "sql_file": source_cfg.get("sql_file") or config.get("sql_file"),
        "write_mode": config.get("write_mode", "append"),
        "tags": config.get("tags", ["ETL", "PYTHON"]),
    }


