# ─────────────────────────────────────────────────────────────────────────────
# Column-name normalisation
# ─────────────────────────────────────────────────────────────────────────────

def _clean_col(name: str) -> str:
    """Normalise: strip accents → lower → replace non-alphanumeric with _ → protect reserved words."""
    name = unicodedata.normalize("NFD", str(name))
    name = "".join(c for c in name if unicodedata.category(c) != "Mn")
    name = re.sub(r"[^a-z0-9]+", "_", name.lower()).strip("_")
    reserved = {"from", "select", "where", "group", "order", "having",
                "user", "table", "index", "start", "end", "begin", "if"}
    if name in reserved:
        name = name + "_"
    return name or "col"


# ─────────────────────────────────────────────────────────────────────────────
# File-scan and checksum helpers
# ─────────────────────────────────────────────────────────────────────────────

def _find_file(watch_path: str, file_name: str):  # -> Optional[str]
    """Return the full path if file_name exists in watch_path, otherwise None."""
    if not os.path.isdir(watch_path):
        return None
    fpath = os.path.join(watch_path, file_name)
    return fpath if os.path.isfile(fpath) else None


def _compute_md5(file_path: str) -> str:
    """Return MD5 hex digest of file bytes."""
    h = hashlib.md5()
    with open(file_path, "rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


# ─────────────────────────────────────────────────────────────────────────────
# Encoding detection (used for CSV pre-flight, then passed to Spark)
# ─────────────────────────────────────────────────────────────────────────────

def _detect_encoding(path: str) -> str:
    try:
        import chardet
        with open(path, "rb") as fh:
            sample = fh.read(65536)
        result = chardet.detect(sample)
        enc = (result.get("encoding") or "utf-8").upper().replace("-", "")
        aliases = {"ASCII": "UTF-8", "UTF8": "UTF-8", "UTF8BOM": "UTF-8",
                   "UTF16": "UTF-16", "LATIN1": "ISO-8859-1", "ISO88591": "ISO-8859-1"}
        return aliases.get(enc, result.get("encoding", "UTF-8"))
    except Exception:
        return "UTF-8"


