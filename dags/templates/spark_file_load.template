def _get_spark():
    from pyspark.sql import SparkSession

    jar_dir  = "/opt/airflow/jars"
    jar_glob = glob.glob(f"{jar_dir}/*.jar")
    jars_str = ",".join(jar_glob)

    scfg    = CONFIG["spark"]
    builder = (
        SparkSession.builder
        .appName(scfg["app_name"])
        .master(scfg["master"])
        .config("spark.executor.memory", scfg["executor_memory"])
        .config("spark.executor.cores",  str(scfg["executor_cores"]))
        .config("spark.driver.memory",   scfg["driver_memory"])
    )
    if jars_str:
        builder = builder.config("spark.jars", jars_str)
    if scfg.get("num_executors"):
        builder = builder.config("spark.executor.instances", str(scfg["num_executors"]))
    for k, v in (scfg.get("extra_conf") or {}).items():
        builder = builder.config(k, v)

    return builder.getOrCreate()


# ─────────────────────────────────────────────────────────────────────────────
# JDBC helpers
# ─────────────────────────────────────────────────────────────────────────────

def _jdbc_url_and_props(conn_id: str):
    hook = get_hook(conn_id)
    uri  = hook.get_uri()
    uri  = re.sub(r"^\w+\+\w+://", lambda m: m.group(0).split("+")[0] + "://", uri)
    from urllib.parse import urlparse
    p        = urlparse(uri)
    db_type  = p.scheme.split("+")[0].lower()
    host, port, db = p.hostname, p.port, p.path.lstrip("/")
    user, pwd = p.username, p.password

    if db_type in ("postgresql", "postgres"):
        jdbc_url = f"jdbc:postgresql://{host}:{port or 5432}/{db}"
        driver   = "org.postgresql.Driver"
    elif db_type == "mysql":
        jdbc_url = f"jdbc:mysql://{host}:{port or 3306}/{db}"
        driver   = "com.mysql.cj.jdbc.Driver"
    elif db_type in ("mssql", "sqlserver"):
        jdbc_url = f"jdbc:sqlserver://{host}:{port or 1433};databaseName={db}"
        driver   = "com.microsoft.sqlserver.jdbc.SQLServerDriver"
    else:
        raise ValueError(f"Unsupported db_type for Spark JDBC: {db_type}")

    return jdbc_url, {"user": user, "password": pwd, "driver": driver}


# ─────────────────────────────────────────────────────────────────────────────
# Registry + schema helpers (driver-side, plain SQLAlchemy)
# ─────────────────────────────────────────────────────────────────────────────

def _get_driver_engine():
    from sqlalchemy import create_engine
    hook = get_hook(CONFIG["target"]["target_db_conn_id"])
    return create_engine(hook.get_uri(), pool_pre_ping=True)


def _checksum_already_registered(schema: str, table: str, checksum: str) -> bool:
    """Return True if this MD5 checksum is already in pipeline.file_load_registry."""
    from sqlalchemy import text
    engine = _get_driver_engine()
    try:
        with engine.connect() as conn:
            r = conn.execute(
                text("""
                    SELECT 1 FROM pipeline.file_load_registry
                    WHERE target_schema = :s AND target_table = :t AND file_checksum = :c
                    LIMIT 1
                """),
                {"s": schema, "t": table, "c": checksum},
            )
            return r.fetchone() is not None
    except Exception:
        return False


def _ensure_registry_table(conn):
    from sqlalchemy import text
    conn.execute(text("CREATE SCHEMA IF NOT EXISTS pipeline"))
    conn.execute(text("""
        CREATE TABLE IF NOT EXISTS pipeline.file_load_registry (
            id              SERIAL PRIMARY KEY,
            dag_id          TEXT,
            target_schema   TEXT,
            target_table    TEXT,
            file_name       TEXT,
            file_path       TEXT,
            file_checksum   TEXT,
            file_size_bytes BIGINT,
            rows_loaded     BIGINT,
            run_id          TEXT,
            loaded_at       TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
            archived_to     TEXT,
            archived_at     TIMESTAMP WITH TIME ZONE
        )
    """))
    conn.execute(text("""
        CREATE UNIQUE INDEX IF NOT EXISTS ux_file_registry_checksum
            ON pipeline.file_load_registry (target_schema, target_table, file_checksum)
    """))


def _ensure_schema(schema: str):
    from sqlalchemy import text
    engine = _get_driver_engine()
    with engine.begin() as conn:
        conn.execute(text(f'CREATE SCHEMA IF NOT EXISTS "{schema}"'))


